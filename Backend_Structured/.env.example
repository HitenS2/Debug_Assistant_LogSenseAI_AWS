# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint.region.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_opensearch_password
OPENSEARCH_INDEX_PATTERN=logs-*

# DynamoDB Tables
DYNAMODB_CONVERSATION_TABLE=ConversationContext
DYNAMODB_METADATA_TABLE=LogMetadata
DYNAMODB_ALERT_TABLE=AlertState

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=2000

# Twilio Configuration (Replace with actual values)
TWILIO_ACCOUNT_SID=TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+1234567890
ONCALL_PHONE_NUMBER=+1234567890
ONCALL_WHATSAPP_NUMBER=whatsapp:+1234567890

# Uterva API Configuration (Replace with actual values)
UTERVA_API_KEY=UTERVA_API_KEY_HERE
UTERVA_API_ENDPOINT=https://api.uterva.com

# Alert Thresholds
ALERT_THRESHOLD_DEFAULT=100
ALERT_WINDOW_SECONDS=300
ALERT_CHECK_INTERVAL_SECONDS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Query Configuration
MAX_QUERY_LENGTH=1000
MAX_LOGS_PER_QUERY=1000
DEFAULT_TIME_RANGE_HOURS=1

# Retry Configuration
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=10.0

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Conversation TTL (90 days in seconds)
CONVERSATION_TTL_SECONDS=7776000
